---
/**
 * TransitWidget.astro
 * Displays today's planetary positions.
 *
 * TODO: Wire to Levite astro-calc-api endpoint once AXIS-Levite bridge is spec'd.
 * Levite owns all ephemeris computation — no third-party astrology apps.
 * Endpoint target: GET /api/transits/today?ayanamsa=lahiri
 *
 * Placeholder data below is for scaffold/design purposes only.
 */

const placeholderTransits = [
  { planet: 'Sun ☉',     sign: 'Pisces',      degree: "29°42'", note: 'Endings, reflection, letting go' },
  { planet: 'Moon ☽',    sign: 'Scorpio',     degree: "14°18'", note: 'Emotional intensity, hidden truths' },
  { planet: 'Mars ♂',    sign: 'Capricorn',   degree: "8°55'",  note: 'Disciplined action, long-game moves' },
  { planet: 'Mercury ☿', sign: 'Aries',       degree: "3°12'",  note: 'Direct talk, fast decisions' },
  { planet: 'Jupiter ♃', sign: 'Taurus',      degree: "21°34'", note: 'Slow growth, material building' },
  { planet: 'Venus ♀',   sign: 'Pisces',      degree: "17°08'", note: 'Compassion, dissolving boundaries' },
  { planet: 'Saturn ♄',  sign: 'Aquarius',    degree: "16°22'", note: 'Systems, accountability, the long view' },
  { planet: 'Rahu ☊',    sign: 'Pisces',      degree: "11°45'", note: 'Where the world is being pulled forward' },
  { planet: 'Ketu ☋',    sign: 'Virgo',       degree: "11°45'", note: 'What the world is releasing' },
];
---

<div class="grid grid-cols-2 md:grid-cols-3 gap-3">
  {placeholderTransits.map((t) => (
    <div class="bg-axis-black/60 border border-axis-indigo-mid/40 rounded p-3">
      <div class="flex justify-between items-start mb-1">
        <span class="text-axis-gold font-mono text-xs">{t.planet}</span>
        <span class="text-gray-600 font-mono text-xs">{t.degree}</span>
      </div>
      <p class="text-white text-sm font-serif">{t.sign}</p>
      <p class="text-gray-500 text-xs mt-1">{t.note}</p>
    </div>
  ))}
</div>
<p class="text-gray-700 font-mono text-xs mt-3 text-right">
  Calculated using actual sky positions · Levite API wiring pending
</p>
