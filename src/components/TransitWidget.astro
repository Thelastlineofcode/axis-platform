---
/**
 * TransitWidget.astro
 *
 * Current status:
 * - UI scaffold only
 * - data below is placeholder content
 * - Levite-backed ephemeris integration is planned but not wired yet
 *
 * When implemented, this should fetch real transit data from the Levite bridge
 * instead of implying live planetary calculations today.
 */

const placeholderTransits = [
  { planet: 'Sun ☉',     sign: 'Sample sign', degree: '—', note: 'Layout preview only' },
  { planet: 'Moon ☽',    sign: 'Sample sign', degree: '—', note: 'Live transit feed not connected yet' },
  { planet: 'Mars ♂',    sign: 'Sample sign', degree: '—', note: 'Levite bridge still pending' },
  { planet: 'Mercury ☿', sign: 'Sample sign', degree: '—', note: 'Use this component as a UI scaffold' },
  { planet: 'Jupiter ♃', sign: 'Sample sign', degree: '—', note: 'Do not treat values here as real sky data' },
  { planet: 'Venus ♀',   sign: 'Sample sign', degree: '—', note: 'Presentation only' },
];
---

<div class="grid grid-cols-2 md:grid-cols-3 gap-3">
  {placeholderTransits.map((t) => (
    <div class="bg-axis-black/60 border border-axis-indigo-mid/40 rounded p-3">
      <div class="flex justify-between items-start mb-1">
        <span class="text-axis-gold font-mono text-xs">{t.planet}</span>
        <span class="text-gray-600 font-mono text-xs">{t.degree}</span>
      </div>
      <p class="text-white text-sm font-serif">{t.sign}</p>
      <p class="text-gray-500 text-xs mt-1">{t.note}</p>
    </div>
  ))}
</div>
<p class="text-gray-700 font-mono text-xs mt-3 text-right">
  Placeholder transit data for layout preview · live Levite ephemeris wiring still pending
</p>
