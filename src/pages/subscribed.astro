---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="You're in — AXIS" description="Welcome to AXIS.">
  <main class="min-h-screen bg-axis-black flex flex-col justify-center items-center text-center px-6">
    <p class="text-axis-gold font-mono text-sm tracking-widest uppercase mb-4">Subscription Confirmed</p>
    <h1 class="text-4xl font-serif text-white mb-4">You&apos;re in the signal chain.</h1>
    <p class="text-gray-400 max-w-md">
      First Mundane Mystic dispatch drops Monday. The sky is already talking.
    </p>
    <a href="/" class="mt-8 text-axis-gold font-mono text-sm hover:underline">← Back to AXIS</a>
  </main>
</BaseLayout>
