---
import BaseLayout from '../layouts/BaseLayout.astro';
import TransitWidget from '../components/TransitWidget.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
import PostCard from '../components/PostCard.astro';

// TODO: Replace with live Sanity GROQ query once projectId is configured
// import { useSanityClient } from '@sanity/astro';
// const client = useSanityClient();
// const posts = await client.fetch(`*[_type == "post"] | order(publishedAt desc)[0..5]`);

const posts: any[] = []; // placeholder until Sanity is wired
---

<BaseLayout
  title="AXIS — Read the Sky. Understand the Moment."
  description="Weekly reads connecting what's happening in the sky to what's happening in the world. Plain English. Real insight. Free to start."
>
  <!-- Hero -->
  <section class="min-h-screen bg-axis-black flex flex-col justify-center items-center text-center px-6 py-24">
    <p class="text-axis-gold font-mono text-sm tracking-widest uppercase mb-4">Sky Intelligence. Plain English.</p>
    <h1 class="text-5xl md:text-7xl font-serif text-white mb-6 leading-tight">
      The sky doesn&apos;t lie.<br />
      <span class="text-axis-gold">Neither do we.</span>
    </h1>
    <p class="text-gray-400 max-w-2xl text-lg mb-10">
      Every week, we connect what&apos;s happening in the sky to what&apos;s happening in your world —
      using the oldest star-tracking traditions on Earth. No fluff. No vague predictions.
      Just clear, honest reads for people who want to understand the moment they&apos;re living in.
    </p>
    <NewsletterSignup />
  </section>

  <!-- Transit Widget -->
  <section class="bg-axis-indigo py-12 px-6">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-axis-gold font-mono text-xs tracking-widest uppercase mb-1">Where the Planets Are Today</h2>
      <p class="text-gray-500 text-xs mb-4">Positions calculated using the actual sky — not the simplified version most apps use.</p>
      <TransitWidget />
    </div>
  </section>

  <!-- Latest Posts -->
  <section class="bg-axis-black py-20 px-6">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-white font-serif text-3xl mb-2">This Week&apos;s Read</h2>
      <p class="text-gray-500 mb-10">What&apos;s moving in the sky, what it means on the ground. Every Monday.</p>

      {posts.length === 0 ? (
        <div class="border border-axis-indigo-mid rounded p-8 text-center">
          <p class="text-gray-600 font-mono text-sm">First issue dropping soon. Subscribe below so you don&apos;t miss it.</p>
        </div>
      ) : (
        <div class="grid gap-8">
          {posts.map((post) => <PostCard post={post} />)}
        </div>
      )}
    </div>
  </section>
</BaseLayout>
